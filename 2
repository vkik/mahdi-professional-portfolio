<script>
// ── SCROLL REVEAL ────────────────────────────────────────────────────────
const revealEls = document.querySelectorAll('.reveal-pending');
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      const parent = entry.target.parentElement;
      const siblings = [...parent.querySelectorAll('.reveal-pending:not(.visible)')];
      const idx = siblings.indexOf(entry.target);
      setTimeout(() => {
        entry.target.classList.add('visible');
      }, Math.min(idx * 95, 420));
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.10, rootMargin: '0px 0px -36px 0px' });
revealEls.forEach(el => observer.observe(el));

// ── NAV ACTIVE HIGHLIGHT ──────────────────────────────────────────────────
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('nav a[href^="#"]');
const navObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      navLinks.forEach(a => {
        a.style.color = a.getAttribute('href') === '#' + entry.target.id
          ? 'oklch(0.72 0.13 68)'
          : '';
      });
    }
  });
}, { threshold: 0.35 });
sections.forEach(s => navObserver.observe(s));

// ── BADGE SCAN ANIMATION ON HOVER ─────────────────────────────────────────
// Additional shimmer effect on badge images when viewport enters
const badgeObserver = new IntersectionObserver((entries) => {
  entries.forEach((entry, idx) => {
    if (entry.isIntersecting) {
      setTimeout(() => {
        entry.target.style.animationPlayState = 'running';
      }, idx * 120);
      badgeObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.2 });
document.querySelectorAll('.badge').forEach(b => badgeObserver.observe(b));
</script>
