<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mahdi Yussuf Abdi Jimale | Civil Engineer & WASH Project Leader</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
<style>
/* ── TOKENS ─────────────────────────────────────────────────────────────── */
:root {
  --bg:        oklch(0.10 0.018 48);
  --surface:   oklch(0.14 0.020 50);
  --surface-2: oklch(0.18 0.022 52);
  --rim:       oklch(0.24 0.025 55);
  --amber:     oklch(0.72 0.13  68);
  --amber-dim: oklch(0.58 0.10  66);
  --terracotta:oklch(0.60 0.12  40);
  --ink:       oklch(0.97 0.005 80);
  --ink-2:     oklch(0.78 0.018 75);
  --ink-3:     oklch(0.55 0.018 65);
  --ease-out:  cubic-bezier(0.22, 1, 0.36, 1);
  --ease-spring: cubic-bezier(0.34, 1.4, 0.64, 1);
}

/* ── RESET ───────────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--ink);
  font-family: 'DM Sans', system-ui, sans-serif;
  font-weight: 400;
  line-height: 1.65;
  overflow-x: hidden;
}

/* ── NOISE GRAIN ─────────────────────────────────────────────────────────── */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 100;
  pointer-events: none;
  opacity: 0.028;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  background-size: 180px 180px;
}

/* ── FLOATING NAV ────────────────────────────────────────────────────────── */
nav {
  position: fixed;
  top: 20px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 90;
  background: oklch(0.14 0.020 50 / 0.82);
  backdrop-filter: blur(18px) saturate(1.3);
  border: 1px solid oklch(0.30 0.025 55 / 0.5);
  border-radius: 999px;
  padding: 10px 28px;
  display: flex;
  align-items: center;
  gap: 32px;
  transition: background 0.4s var(--ease-out), border-color 0.4s;
}
nav a {
  color: var(--ink-2);
  text-decoration: none;
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  transition: color 0.25s var(--ease-out);
}
nav a:hover { color: var(--amber); }
.nav-logo {
  font-family: 'Playfair Display', serif;
  font-weight: 900;
  font-size: 0.9rem;
  color: var(--amber);
  letter-spacing: -0.01em;
  white-space: nowrap;
}

/* ── HERO ────────────────────────────────────────────────────────────────── */
.hero {
  position: relative;
  min-height: 100dvh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
}

/* Geological strata */
.strata-canvas {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
}
.strata-canvas svg { width: 100%; height: 100%; opacity: 0.55; }
.strata-layer { animation: drift linear infinite; transform-origin: center center; }
.strata-layer:nth-child(1)  { animation-duration: 28s; }
.strata-layer:nth-child(2)  { animation-duration: 36s; animation-direction: reverse; }
.strata-layer:nth-child(3)  { animation-duration: 22s; }
.strata-layer:nth-child(4)  { animation-duration: 44s; animation-direction: reverse; }
.strata-layer:nth-child(5)  { animation-duration: 31s; }
.strata-layer:nth-child(6)  { animation-duration: 19s; animation-direction: reverse; }
@keyframes drift {
  0%   { transform: translateX(0) translateY(0) scaleX(1); }
  33%  { transform: translateX(-18px) translateY(6px) scaleX(1.012); }
  66%  { transform: translateX(12px) translateY(-9px) scaleX(0.988); }
  100% { transform: translateX(0) translateY(0) scaleX(1); }
}

.hero::after {
  content: '';
  position: absolute;
  top: 15%; bottom: 15%; left: 50%;
  width: 1px;
  background: linear-gradient(to bottom, transparent, var(--amber) 30%, var(--amber) 70%, transparent);
  opacity: 0.25;
  z-index: 2;
}

/* ── HERO LEFT (photo + text) ────────────────────────────────────────────── */
.hero-left {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 120px 6% 80px 8%;
  gap: 0;
}

/* Portrait — adapted from old CV's double-bezel ring pattern */
.portrait-shell {
  position: relative;
  width: 130px;
  height: 130px;
  margin-bottom: 32px;
  isolation: isolate;
  flex-shrink: 0;
}
.portrait-shell::before {
  content: '';
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  background: conic-gradient(
    from 120deg,
    oklch(0.72 0.13 68),
    oklch(0.97 0.005 80 / 0.5),
    oklch(0.60 0.12 40),
    oklch(0.58 0.10 66),
    oklch(0.72 0.13 68)
  );
  animation: ring-turn 9s linear infinite;
  z-index: -2;
}
.portrait-shell::after {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 50%;
  background: var(--bg);
  z-index: -1;
}
@keyframes ring-turn { to { transform: rotate(360deg); } }

.portrait-frame {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  border: 1px solid oklch(0.72 0.13 68 / 0.3);
  box-shadow:
    0 0 0 1px oklch(0.10 0.018 48 / 0.8),
    0 20px 50px -16px oklch(0.10 0.018 48 / 0.9);
  position: relative;
}
.portrait-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 50% 18%;
  transform: scale(1.18);
  filter: saturate(0.95) contrast(1.04);
  display: block;
}
/* Amber glow overlay — screen blend */
.portrait-frame::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, oklch(0.72 0.13 68 / 0.12), transparent 65%);
  pointer-events: none;
}
.portrait-tag {
  position: absolute;
  right: -6px;
  bottom: 6px;
  background: oklch(0.72 0.13 68);
  color: oklch(0.10 0.018 48);
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  padding: 4px 9px;
  border-radius: 999px;
  box-shadow: 0 4px 12px oklch(0.72 0.13 68 / 0.4);
  white-space: nowrap;
  z-index: 4;
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}
.hero-eyebrow-line { width: 32px; height: 1px; background: var(--amber); }
.hero-eyebrow span {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--amber);
}
.hero-name {
  font-family: 'Playfair Display', serif;
  font-weight: 900;
  font-size: clamp(2.4rem, 4.8vw, 3.8rem);
  line-height: 1.05;
  letter-spacing: -0.03em;
  text-wrap: balance;
  color: var(--ink);
  margin-bottom: 8px;
}
.hero-name em { font-style: italic; color: var(--amber); }
.hero-title {
  font-size: clamp(0.8rem, 1.3vw, 0.95rem);
  font-weight: 400;
  color: var(--ink-2);
  margin-bottom: 22px;
  letter-spacing: 0.01em;
  line-height: 1.6;
}
.hero-desc {
  font-size: 0.9rem;
  color: var(--ink-3);
  max-width: 42ch;
  margin-bottom: 36px;
  line-height: 1.75;
}
.cta-row { display: flex; gap: 14px; flex-wrap: wrap; }
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 0;
  background: var(--amber);
  color: oklch(0.10 0.018 48);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  text-decoration: none;
  border-radius: 999px;
  padding: 12px 8px 12px 22px;
  transition: transform 0.3s var(--ease-spring), box-shadow 0.3s var(--ease-out);
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 32px oklch(0.72 0.13 68 / 0.35);
}
.btn-primary:active { transform: scale(0.97); }
.btn-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30px; height: 30px;
  border-radius: 50%;
  background: oklch(0.10 0.018 48 / 0.22);
  margin-left: 12px;
  font-size: 0.9rem;
  transition: transform 0.3s var(--ease-spring);
}
.btn-primary:hover .btn-icon { transform: translate(2px, -2px) scale(1.1); }
.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: var(--ink-2);
  font-size: 0.82rem;
  font-weight: 500;
  text-decoration: none;
  border-radius: 999px;
  border: 1px solid var(--rim);
  padding: 12px 22px;
  transition: color 0.25s, border-color 0.25s, transform 0.3s var(--ease-spring);
}
.btn-secondary:hover { color: var(--amber); border-color: var(--amber-dim); transform: translateY(-1px); }

/* ── HERO RIGHT ──────────────────────────────────────────────────────────── */
.hero-right {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 120px 8% 80px 6%;
  gap: 16px;
}
.stat-block {
  background: var(--surface);
  border: 1px solid var(--rim);
  border-radius: 20px;
  padding: 20px 24px;
  position: relative;
  overflow: hidden;
  transition: transform 0.4s var(--ease-out), border-color 0.3s;
}
.stat-block::before {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 60%; height: 1px;
  background: linear-gradient(to left, transparent, var(--amber-dim));
  opacity: 0.4;
}
.stat-block:hover { transform: translateY(-3px); border-color: var(--amber-dim); }
.stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.stat-num {
  font-family: 'Playfair Display', serif;
  font-weight: 900;
  font-size: 2.2rem;
  color: var(--amber);
  letter-spacing: -0.03em;
  line-height: 1;
  margin-bottom: 4px;
}
.stat-label {
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--ink-3);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.stat-certs { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px; }
.cert-pill {
  background: oklch(0.72 0.13 68 / 0.12);
  border: 1px solid oklch(0.72 0.13 68 / 0.3);
  color: var(--amber);
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  padding: 5px 11px;
  border-radius: 999px;
}

/* ── SHARED SECTION STYLES ───────────────────────────────────────────────── */
section { padding: 96px 8%; position: relative; }
.section-marker {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 48px;
}
.section-marker-line {
  width: 40px; height: 1px;
  background: linear-gradient(to right, var(--amber-dim), transparent);
  opacity: 0.5;
}
.section-marker h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ink);
  text-wrap: balance;
}
.section-marker h2 em { color: var(--amber); font-style: italic; }

/* ── ABOUT ───────────────────────────────────────────────────────────────── */
#about { background: var(--surface); }
.about-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 60px; align-items: start; }
.about-body { font-size: 1rem; color: var(--ink-2); line-height: 1.85; max-width: 62ch; }
.about-body p + p { margin-top: 20px; }
.about-body strong { color: var(--amber); font-weight: 600; }
.about-aside { display: flex; flex-direction: column; gap: 12px; }
.aside-card {
  background: var(--bg);
  border: 1px solid var(--rim);
  border-radius: 14px;
  padding: 16px 20px;
}
.aside-card-label {
  font-size: 0.66rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 5px;
}
.aside-card-val { font-size: 0.87rem; color: var(--ink-2); }

/* ── EXPERTISE BENTO ─────────────────────────────────────────────────────── */
.expertise-bento {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 14px;
}
.ex-card {
  background: var(--surface);
  border: 1px solid var(--rim);
  border-radius: 18px;
  padding: 26px;
  position: relative;
  overflow: hidden;
  transition: transform 0.4s var(--ease-out), border-color 0.3s;
}
.ex-card::after {
  content: '';
  position: absolute;
  bottom: -30%; right: -15%;
  width: 45%; padding-bottom: 45%;
  border-radius: 50%;
  background: var(--amber);
  opacity: 0.04;
  transition: opacity 0.4s;
}
.ex-card:hover { transform: translateY(-4px); border-color: var(--amber-dim); }
.ex-card:hover::after { opacity: 0.09; }
.ex-card-a { grid-column: span 5; }
.ex-card-b { grid-column: span 7; }
.ex-card-c { grid-column: span 4; }
.ex-card-d { grid-column: span 4; }
.ex-card-e { grid-column: span 4; }
.ex-card-f { grid-column: span 6; }
.ex-card-g { grid-column: span 6; }
.ex-icon {
  width: 36px; height: 36px;
  border-radius: 9px;
  background: oklch(0.72 0.13 68 / 0.1);
  border: 1px solid oklch(0.72 0.13 68 / 0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem;
  margin-bottom: 14px;
}
.ex-title {
  font-family: 'Playfair Display', serif;
  font-size: 1rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 7px;
}
.ex-desc { font-size: 0.8rem; color: var(--ink-3); line-height: 1.6; }

/* ── EXPERIENCE TIMELINE ─────────────────────────────────────────────────── */
#experience { background: var(--surface); }
.timeline {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 0 44px;
  position: relative;
}
.timeline::before {
  content: '';
  position: absolute;
  top: 12px; bottom: 12px;
  left: 159px;
  width: 1px;
  background: linear-gradient(to bottom, var(--amber-dim), transparent 90%);
  opacity: 0.35;
}
.tl-year {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: var(--amber-dim);
  padding-top: 3px;
  text-align: right;
  letter-spacing: 0.05em;
}
.tl-content { padding-bottom: 44px; position: relative; }
.tl-content::before {
  content: '';
  position: absolute;
  left: -49px; top: 8px;
  width: 9px; height: 9px;
  border-radius: 50%;
  background: var(--amber);
  box-shadow: 0 0 0 4px oklch(0.72 0.13 68 / 0.15);
}
.tl-org {
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 3px;
}
.tl-role {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 9px;
}
.tl-desc { font-size: 0.86rem; color: var(--ink-3); line-height: 1.7; max-width: 56ch; }

/* ── PROJECTS ────────────────────────────────────────────────────────────── */
.projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.proj-card {
  background: var(--surface);
  border: 1px solid var(--rim);
  border-radius: 18px;
  padding: 30px 26px;
  position: relative;
  overflow: hidden;
  transition: transform 0.4s var(--ease-out), border-color 0.3s;
}
.proj-card::before {
  content: attr(data-num);
  position: absolute;
  top: -12px; right: 20px;
  font-family: 'Playfair Display', serif;
  font-size: 5rem;
  font-weight: 900;
  color: var(--amber);
  opacity: 0.05;
  line-height: 1;
  pointer-events: none;
  transition: opacity 0.4s;
}
.proj-card:hover { transform: translateY(-5px); border-color: var(--amber-dim); }
.proj-card:hover::before { opacity: 0.10; }
.proj-num { font-family: 'DM Mono', monospace; font-size: 0.68rem; color: var(--amber-dim); margin-bottom: 10px; }
.proj-title {
  font-family: 'Playfair Display', serif;
  font-size: 1rem;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.3;
  margin-bottom: 9px;
}
.proj-desc { font-size: 0.79rem; color: var(--ink-3); line-height: 1.65; }

/* ── CREDLY BADGES ───────────────────────────────────────────────────────── */
#certifications { background: var(--surface); }
.badges-intro {
  display: flex;
  align-items: center;
  gap: 12px;
  background: oklch(0.72 0.13 68 / 0.08);
  border: 1px solid oklch(0.72 0.13 68 / 0.2);
  border-radius: 12px;
  padding: 13px 18px;
  margin-bottom: 32px;
  font-size: 0.84rem;
  color: var(--ink-2);
}
.badges-intro-icon {
  font-size: 1.1rem;
  flex-shrink: 0;
}
.badge-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  text-decoration: none;
  padding: 24px 16px 18px;
  background: var(--bg);
  border: 1px solid var(--rim);
  border-radius: 18px;
  position: relative;
  overflow: hidden;
  transition: transform 0.3s var(--ease-out), border-color 0.3s, box-shadow 0.3s;
  /* Double-bezel outer glow on hover */
}
.badge::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 18px;
  background: radial-gradient(circle at 50% 0%, oklch(0.72 0.13 68 / 0.08), transparent 70%);
  opacity: 0;
  transition: opacity 0.4s;
}
.badge:hover {
  transform: translateY(-6px);
  border-color: var(--amber-dim);
  box-shadow:
    0 0 0 1px oklch(0.72 0.13 68 / 0.15),
    0 20px 40px -16px oklch(0.10 0.018 48 / 0.8);
}
.badge:hover::before { opacity: 1; }
.badge img {
  width: 88px;
  height: 88px;
  object-fit: contain;
  margin-bottom: 14px;
  transition: transform 0.4s var(--ease-spring), filter 0.3s;
  filter: saturate(0.9);
}
.badge:hover img {
  transform: scale(1.1) rotate(-3deg);
  filter: saturate(1.1) drop-shadow(0 8px 16px oklch(0.72 0.13 68 / 0.25));
}
.badge-name {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.35;
  margin-bottom: 3px;
}
.badge-issuer {
  font-size: 0.68rem;
  font-weight: 400;
  color: var(--ink-3);
  margin-bottom: 10px;
}
.badge-verify {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.65rem;
  font-weight: 600;
  color: var(--amber);
  background: oklch(0.72 0.13 68 / 0.1);
  border: 1px solid oklch(0.72 0.13 68 / 0.25);
  padding: 4px 10px;
  border-radius: 999px;
  letter-spacing: 0.04em;
  transition: background 0.25s, border-color 0.25s;
}
.badge:hover .badge-verify {
  background: oklch(0.72 0.13 68 / 0.18);
  border-color: oklch(0.72 0.13 68 / 0.5);
}
.badge-verify-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--amber);
  animation: badge-pulse 2s ease-in-out infinite;
}
@keyframes badge-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}

/* ── CONTACT ─────────────────────────────────────────────────────────────── */
#contact { }
.contact-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}
.contact-heading {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--ink);
  text-wrap: balance;
}
.contact-heading em { color: var(--amber); font-style: italic; }
.contact-sub {
  font-size: 0.92rem;
  color: var(--ink-3);
  line-height: 1.75;
  margin-top: 18px;
  max-width: 44ch;
}
.contact-links { display: flex; flex-direction: column; gap: 12px; }
.contact-link {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--surface);
  border: 1px solid var(--rim);
  border-radius: 13px;
  padding: 15px 18px;
  text-decoration: none;
  color: var(--ink-2);
  font-size: 0.88rem;
